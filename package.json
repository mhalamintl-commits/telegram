    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "nodemailer": "^9.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "telegram": "^2.26.22",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
